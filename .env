###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=your_secret_key_change_in_production_32chars
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://parking_user:123456@127.0.0.1:5432/parking_db?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=
JWT_TTL=3600
###< lexik/jwt-authentication-bundle ###

###> Rate Limiting ###
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100
###< Rate Limiting ###

###> Parking Config ###
PARKING_DEFAULT_HOURLY_RATE=50
PARKING_DEFAULT_MINUTE_RATE=1
PARKING_BOOKING_EXPIRY_MINUTES=15
###< Parking Config ###

###> Redis (optional) ###
REDIS_URL=redis://localhost:6379
###< Redis ###

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
